---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChangelogSection from "../components/ChangelogSection.astro";
import { GITHUB_RELEASES_URL } from "@ybdownload/shared/urls";
import { getDesktopReleases, getExtensionReleases } from "../lib/github";

const [desktop, extension] = await Promise.all([
  getDesktopReleases(),
  getExtensionReleases(),
]);
---

<BaseLayout
  title="Changelog"
  description="Release history for YBDownloader desktop and extension."
>
  <section class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="font-display text-4xl font-bold tracking-tight md:text-5xl">
      Changelog
    </h1>
    <p class="mt-4 max-w-2xl text-muted">
      Latest release notes from GitHub. Download links and the full tag list
      live on <a href="/releases" class="text-accent hover:text-accent-soft"
        >Releases</a
      >.
    </p>

    <div class="mt-16 grid gap-16 lg:grid-cols-2">
      <ChangelogSection
        title="Desktop"
        releases={desktop}
        emptyMessage="No desktop releases fetched yet."
      />
      <ChangelogSection
        title="Extension"
        releases={extension}
        emptyMessage="No extension releases fetched yet."
        extension
      />
    </div>

    <p class="mt-12 text-center text-sm text-muted">
      <a
        href={GITHUB_RELEASES_URL}
        class="font-semibold text-accent hover:text-accent-soft"
        rel="noopener noreferrer"
        target="_blank"
      >
        View all releases on GitHub →
      </a>
    </p>
  </section>
</BaseLayout>
