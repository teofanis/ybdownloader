---
import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/600.css";
import "@fontsource/bricolage-grotesque/700.css";
import "@fontsource/bricolage-grotesque/800.css";
import "../styles/global.css";
import { getImage } from "astro:assets";
import AppLogo from "../components/AppLogo.astro";
import GitHubStar from "../components/GitHubStar.astro";
import logo from "../assets/logo.png";
import { site, nav } from "../data/site";
import { getRepoStarCount } from "../lib/github";
import { legalNotice } from "../data/legal";
import {
  GITHUB_ISSUES_URL,
  GITHUB_REPO_URL,
  GITHUB_RELEASES_URL,
  SPONSOR_URL,
} from "@ybdownload/shared/urls";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;

const pageTitle = title === site.name ? title : `${title} · ${site.name}`;

const favicon = await getImage({
  src: logo,
  width: 48,
  height: 48,
  format: "png",
});

const starCount = await getRepoStarCount();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={favicon.src} sizes="48x48" />
    <title>{pageTitle}</title>
  </head>
  <body class="relative overflow-x-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 bg-grid bg-grid-size opacity-40"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none fixed -left-32 top-0 h-[28rem] w-[28rem] rounded-full bg-accent/15 blur-3xl md:bg-accent/20 md:blur-[120px]"
    >
    </div>

    <header
      class="sticky top-0 z-50 border-b border-line/80 bg-canvas/95 md:bg-canvas/80 md:backdrop-blur-xl"
    >
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-2 px-4 py-3 sm:gap-4 sm:px-6 sm:py-4 md:gap-6"
      >
        <a
          href="/"
          class="group flex min-w-0 shrink items-center gap-2 sm:gap-3"
        >
          <AppLogo
            size={36}
            eager
            class="shrink-0 rounded-lg shadow-glow transition group-hover:scale-105"
          />
          <span
            class="truncate font-display text-base font-bold tracking-tight sm:text-lg"
            >{site.name}</span
          >
        </a>
        <nav class="hidden items-center gap-6 text-sm text-muted md:flex">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="cursor-pointer transition hover:text-white"
                aria-current={
                  Astro.url.pathname === item.href ? "page" : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="flex shrink-0 items-center gap-1.5 sm:gap-2 md:gap-3">
          <GitHubStar stars={starCount} />
          <a
            href="/download"
            class="cursor-pointer rounded-full bg-accent px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-accent-soft sm:px-4 sm:py-2 sm:text-sm"
          >
            Download
          </a>
        </div>
      </div>
    </header>

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 mt-24 border-t border-line/80">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-12 text-sm text-muted md:flex-row md:items-center md:justify-between"
      >
        <div class="max-w-xl space-y-2">
          <p>
            {site.name} — open source under MIT. {legalNotice.short}
          </p>
          <p class="text-xs leading-relaxed text-zinc-500">
            <a
              href="/docs#legal"
              class="text-zinc-400 underline-offset-2 hover:text-white hover:underline"
            >
              Full legal notice
            </a>
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <GitHubStar stars={starCount} />
          <a href={GITHUB_REPO_URL} class="cursor-pointer hover:text-white"
            >GitHub</a
          >
          <a href={GITHUB_RELEASES_URL} class="cursor-pointer hover:text-white"
            >Releases</a
          >
          <a href={GITHUB_ISSUES_URL} class="cursor-pointer hover:text-white"
            >Issues</a
          >
          <a href={SPONSOR_URL} class="cursor-pointer hover:text-white"
            >Sponsor</a
          >
        </div>
      </div>
    </footer>
    <script>
      import { scheduleLiveDataRefresh } from "../lib/live-client";

      scheduleLiveDataRefresh();
    </script>
  </body>
</html>
