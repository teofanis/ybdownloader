---
import { features } from "../data/site";
---

<section class="mx-auto max-w-6xl px-6 py-20">
  <div class="mb-12 max-w-2xl">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">
      Features
    </p>
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
      Everything in one native app
    </h2>
  </div>
  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map((feature, index) => (
        <article
          class="rounded-2xl border border-line bg-panel/60 p-6 transition hover:-translate-y-0.5 hover:border-accent/30"
          style={`animation-delay: ${index * 80}ms`}
        >
          <h3 class="font-display text-lg font-semibold">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{feature.body}</p>
        </article>
      ))
    }
  </div>
</section>
