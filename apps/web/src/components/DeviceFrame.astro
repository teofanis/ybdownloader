---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  priority?: boolean;
  variant?: "hero" | "section";
  class?: string;
}

const {
  image,
  alt,
  priority = false,
  variant = "section",
  class: className = "",
} = Astro.props;

const widths =
  variant === "hero" ? [640, 960, 1280, 1536] : [480, 720, 960, 1280];
const sizes =
  variant === "hero"
    ? "(min-width: 1024px) min(960px, 52vw), 100vw"
    : "(min-width: 1024px) min(480px, 46vw), 100vw";
---

<div class:list={["device-frame group", className]}>
  <div
    class="device-frame__chrome flex items-center gap-2 border-b border-white/10 bg-zinc-900/90 px-4 py-3"
  >
    <span class="h-3 w-3 rounded-full bg-[#ff5f57]" aria-hidden="true"></span>
    <span class="h-3 w-3 rounded-full bg-[#febc2e]" aria-hidden="true"></span>
    <span class="h-3 w-3 rounded-full bg-[#28c840]" aria-hidden="true"></span>
    <span class="ml-3 text-xs font-medium text-zinc-500">YBDownloader</span>
  </div>
  <div class="device-frame__screen overflow-hidden bg-zinc-950">
    <Image
      src={image}
      alt={alt}
      widths={widths}
      sizes={sizes}
      format="webp"
      quality={82}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={priority ? "high" : "low"}
      class="block h-auto w-full"
    />
  </div>
</div>

<style>
  .device-frame {
    border: 1px solid rgb(39 39 42 / 0.9);
    border-radius: 1.25rem;
    overflow: hidden;
    background: linear-gradient(180deg, rgb(24 24 27) 0%, rgb(9 9 11) 100%);
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.03) inset,
      0 30px 80px -30px rgb(225 29 46 / 0.35),
      0 24px 60px -40px rgb(0 0 0 / 0.8);
    contain: layout style paint;
  }

  @media (hover: hover) and (pointer: fine) {
    .device-frame {
      transition:
        transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .device-frame:hover {
      transform: translateY(-4px);
      box-shadow:
        0 0 0 1px rgb(255 255 255 / 0.05) inset,
        0 36px 100px -24px rgb(225 29 46 / 0.42),
        0 28px 70px -36px rgb(0 0 0 / 0.85);
    }
  }

  .device-frame__screen :global(img) {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .device-frame {
      transition: none;
    }

    .device-frame:hover {
      transform: none;
    }
  }
</style>
