---
import { legalNotice } from "../data/legal";

interface Props {
  variant?: "compact" | "full";
}

const { variant = "compact" } = Astro.props;
---

{
  variant === "compact" ? (
    <aside
      class="rounded-2xl border border-amber-500/20 bg-amber-500/5 px-5 py-4 text-sm leading-relaxed text-zinc-300"
      role="note"
      aria-label="Legal notice"
    >
      <p class="font-semibold text-amber-200/90">Legal notice</p>
      <p class="mt-2">{legalNotice.short}</p>
    </aside>
  ) : (
    <aside
      class="rounded-2xl border border-line bg-panel/60 p-6 text-sm leading-relaxed text-muted"
      role="note"
      aria-label="Legal notice"
    >
      <h2 class="font-display text-lg font-semibold text-white">
        Legal notice
      </h2>
      <p class="mt-3 text-zinc-300">{legalNotice.full}</p>
      <ul class="mt-4 list-disc space-y-2 pl-5">
        {legalNotice.bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </aside>
  )
}
