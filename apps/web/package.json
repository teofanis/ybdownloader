{
  "name": "@ybdownload/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview --port 4321",
    "lint": "astro check && prettier --check .",
    "test": "vitest run",
    "lighthouse:ci": "lhci autorun",
    "lighthouse:ci:live": "lhci autorun",
    "lighthouse:pr-comment": "node ./scripts/lighthouse-pr-comment.mjs",
    "type-check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:pages": "wrangler pages deploy dist --project-name=ybdownload --branch=main"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/dm-sans": "^5.2.8",
    "@ybdownload/shared": "workspace:*",
    "astro": "^6.4.8",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.19",
    "@ybdownload/tsconfig": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.2",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@lhci/cli": "^0.15.1",
    "wrangler": "^4.105.0"
  }
}
